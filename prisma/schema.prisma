generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OWNER
  MANAGER
  MEMBER
  VIEWER
}

enum PlanType {
  FREE
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  EXPIRED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

enum ServiceOrderStatus {
  PENDING
  IN_PROGRESS
  WAITING_PARTS
  WAITING_APPROVAL
  COMPLETED
  DELIVERED
  CANCELED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum PipelineStage {
  LEAD
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum TransactionType {
  REVENUE
  EXPENSE
  TRANSFER
}

enum TransactionCategory {
  SALES
  SERVICES
  PRODUCTS
  SALARY
  RENT
  UTILITIES
  TAXES
  MARKETING
  SUPPLIES
  MAINTENANCE
  OTHER
}

enum PaymentMethod {
  PIX
  BOLETO
  CREDIT_CARD
  DEBIT_CARD
  CASH
  TRANSFER
  STRIPE
  MERCADO_PAGO
  ASAAS
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  emailVerified  DateTime?
  name           String?
  avatarUrl      String?
  phone          String?
  role           UserRole @default(MEMBER)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  accounts      Account[]
  sessions      Session[]
  companyUsers  CompanyUser[]
  employee      Employee?
  notifications Notification[]
  auditLogs     AuditLog[]
  createdTickets Ticket[] @relation("CreatedBy")
  assignedTickets Ticket[] @relation("AssignedTo")
  messages      Message[]
  loginAttempts LoginAttempt[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ipAddress String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  document    String?
  phone       String?
  email       String?
  logoUrl     String?
  website     String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  plan        PlanType @default(FREE)
  subscriptionId String?
  trialEndsAt DateTime?
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  users        CompanyUser[]
  employees    Employee[]
  clients      Client[]
  leads        Lead[]
  products     Product[]
  categories   Category[]
  suppliers    Supplier[]
  orders       Order[]
  serviceOrders ServiceOrder[]
  tickets      Ticket[]
  transactions Transaction[]
  recurringTransactions RecurringTransaction[]
  invoices     Invoice[]
  payments     Payment[]
  pipelines    Pipeline[]
  calendars    CalendarEntry[]
  documents    Document[]
  integrations Integration[]
  notifications Notification[]
  automations  Automation[]
  auditLogs    AuditLog[]
  chatRooms    ChatRoom[]
  whatsAppConnections WhatsAppConnection[]
  deals        Deal[]
  documentFolders DocumentFolder[]
  pipelineStageConfigs PipelineStageConfig[]

  @@index([slug])
  @@index([plan])
  @@map("companies")
}

model CompanyUser {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      UserRole @default(MEMBER)
  invitedAt DateTime?
  joinedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId])
  @@map("company_users")
}

model Employee {
  id          String   @id @default(cuid())
  companyId   String
  userId      String   @unique
  name        String
  email       String
  phone       String?
  position    String?
  department  String?
  salary      Decimal?
  hireDate    DateTime?
  isActive    Boolean  @default(true)
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("employees")
}

model Client {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  email       String?
  phone       String?
  document    String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  notes       String?
  tags        String[]
  avatarUrl   String?
  status      String   @default("ACTIVE")
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders        Order[]
  serviceOrders ServiceOrder[]
  transactions  Transaction[]
  invoices      Invoice[]
  payments      Payment[]
  clientNotes   ClientNote[]
  contacts      ClientContact[]
  deals         Deal[]

  @@index([companyId])
  @@index([email])
  @@index([phone])
  @@map("clients")
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_contacts")
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  content   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_notes")
}


model Lead {
  id          String      @id @default(cuid())
  companyId   String
  name        String
  email       String?
  phone       String?
  companyName String?     @map("company")
  position    String?
  source      String?
  status      LeadStatus  @default(NEW)
  score       Int         @default(0)
  notes       String?
  assignedTo  String?
  convertedToClientId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal    Deal?

  @@index([companyId])
  @@index([status])
  @@index([email])
  @@map("leads")
}

model Pipeline {
  id        String   @id @default(cuid())
  companyId String
  name      String
  stages    PipelineStageConfig[]
  deals     Deal[]
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("pipelines")
}

model PipelineStageConfig {
  id         String        @id @default(cuid())
  pipelineId String
  companyId  String
  name       String
  stage      PipelineStage
  order      Int
  color      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  pipeline Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId])
  @@index([companyId])
  @@map("pipeline_stages")
}

model Deal {
  id                String        @id @default(cuid())
  companyId         String
  pipelineId        String
  stageId           String
  clientId          String?
  leadId            String?   @unique
  title             String
  value             Decimal       @default(0)
  currency          String        @default("BRL")
  probability       Int           @default(0)
  expectedCloseDate DateTime?
  notes             String?
  assignedTo        String?
  order             Int           @default(0)
  lostReason        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pipeline Pipeline            @relation(fields: [pipelineId], references: [id])
  stage    PipelineStageConfig @relation(fields: [stageId], references: [id])
  client   Client?             @relation(fields: [clientId], references: [id])
  lead     Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  activities DealActivity[]

  @@index([companyId])
  @@index([pipelineId])
  @@index([stageId])
  @@map("deals")
}

model DealActivity {
  id        String   @id @default(cuid())
  dealId    String
  type      String
  description String
  authorId  String?
  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("deal_activities")
}

model CalendarEntry {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  allDay      Boolean  @default(false)
  type        String   @default("EVENT")
  status      String   @default("SCHEDULED")
  color       String?
  location    String?
  createdBy   String
  assignedTo  String?
  clientId    String?
  recurrence  RecurrenceType?
  recurrenceEnd DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([date])
  @@index([createdBy])
  @@map("calendar_entries")
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  categoryId  String?
  name        String
  description String?
  sku         String?
  barcode     String?
  price       Decimal  @default(0)
  costPrice   Decimal?
  comparePrice Decimal?
  unit        String   @default("un")
  minStock    Int      @default(0)
  maxStock    Int?
  weight      Decimal?
  height      Decimal?
  width       Decimal?
  length      Decimal?
  images      String[]
  tags        String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category         Category?         @relation(fields: [categoryId], references: [id])
  stockMovements   StockMovement[]
  orderItems       OrderItem[]
  serviceOrderItems ServiceOrderItem[]

  @@index([companyId])
  @@index([sku])
  @@index([categoryId])
  @@map("products")
}

model Category {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  color       String?
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([companyId])
  @@index([parentId])
  @@map("categories")
}

model Supplier {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  email       String?
  phone       String?
  document    String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  contactName String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@index([companyId])
  @@map("suppliers")
}

model Order {
  id              String       @id @default(cuid())
  companyId       String
  clientId        String?
  supplierId      String?
  number          String       @unique
  type            String       @default("SALE")
  status          OrderStatus  @default(PENDING)
  items           OrderItem[]
  subtotal        Decimal      @default(0)
  discount        Decimal      @default(0)
  shipping        Decimal      @default(0)
  tax             Decimal      @default(0)
  total           Decimal      @default(0)
  paymentMethod   PaymentMethod?
  paymentStatus   String       @default("PENDING")
  installments    Int          @default(1)
  notes           String?
  internalNotes   String?
  trackingCode    String?
  estimatedDelivery DateTime?
  deliveredAt     DateTime?
  canceledAt      DateTime?
  canceledReason  String?
  createdBy       String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  payments Payment[]

  @@index([companyId])
  @@index([clientId])
  @@index([supplierId])
  @@index([number])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  name      String
  quantity  Decimal  @default(1)
  unitPrice Decimal  @default(0)
  total     Decimal  @default(0)
  notes     String?
  createdAt DateTime @default(now())

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model ServiceOrder {
  id            String             @id @default(cuid())
  companyId     String
  clientId      String?
  number        String             @unique
  title         String
  description   String?
  status        ServiceOrderStatus @default(PENDING)
  priority      TicketPriority     @default(MEDIUM)
  category      String?
  items         ServiceOrderItem[]
  assignedTo    String?
  entryDate     DateTime           @default(now())
  startDate     DateTime?
  completionDate DateTime?
  deliveryDate  DateTime?
  total         Decimal            @default(0)
  discount      Decimal            @default(0)
  paymentMethod PaymentMethod?
  paymentStatus String             @default("PENDING")
  notes         String?
  internalNotes String?
  signatures    Json?
  photos        String[]
  documents     String[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [clientId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([number])
  @@index([status])
  @@map("service_orders")
}

model ServiceOrderItem {
  id             String   @id @default(cuid())
  serviceOrderId String
  productId      String?
  type           String   @default("SERVICE")
  name           String
  description    String?
  quantity       Decimal  @default(1)
  unitPrice      Decimal  @default(0)
  total          Decimal  @default(0)
  createdAt      DateTime @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id])

  @@index([serviceOrderId])
  @@map("service_order_items")
}

model StockMovement {
  id        String   @id @default(cuid())
  companyId String
  productId String
  type      String
  quantity  Decimal
  unitCost  Decimal?
  reason    String?
  reference String?
  createdBy String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Transaction {
  id              String            @id @default(cuid())
  companyId       String
  clientId        String?
  description     String
  amount          Decimal
  type            TransactionType
  category        TransactionCategory?
  paymentMethod   PaymentMethod?
  status          String            @default("PENDING")
  date            DateTime
  dueDate         DateTime?
  paidAt          DateTime?
  recurringId     String?
  receipt         String?
  notes           String?
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [clientId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([date])
  @@index([type])
  @@index([status])
  @@map("transactions")
}

model RecurringTransaction {
  id          String          @id @default(cuid())
  companyId   String
  description String
  amount      Decimal
  type        TransactionType
  category    TransactionCategory?
  frequency   RecurrenceType
  interval    Int             @default(1)
  dayOfMonth  Int?
  dayOfWeek   Int?
  startDate   DateTime
  endDate     DateTime?
  nextDate    DateTime
  status      String          @default("ACTIVE")
  notes       String?
  createdBy   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([nextDate])
  @@map("recurring_transactions")
}

model Invoice {
  id          String   @id @default(cuid())
  companyId   String
  clientId    String?
  number      String   @unique
  type        String   @default("SALE")
  status      String   @default("PENDING")
  items       Json
  subtotal    Decimal  @default(0)
  discount    Decimal  @default(0)
  tax         Decimal  @default(0)
  total       Decimal  @default(0)
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [clientId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([number])
  @@map("invoices")
}

model Payment {
  id            String   @id @default(cuid())
  companyId     String
  clientId      String?
  orderId       String?
  invoiceId     String?
  amount        Decimal
  fee           Decimal  @default(0)
  netAmount     Decimal  @default(0)
  method        PaymentMethod
  status        String   @default("PENDING")
  gateway       String?
  gatewayId     String?
  pixCode       String?
  boletoCode    String?
  boletoUrl     String?
  cardLastDigits String?
  installments  Int      @default(1)
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [clientId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([orderId])
  @@index([gatewayId])
  @@map("payments")
}

model Ticket {
  id          String         @id @default(cuid())
  companyId   String
  title       String
  description String?
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  clientId    String?
  orderId     String?
  serviceOrderId String?
  createdById String
  assignedToId String?
  tags        String[]
  dueDate     DateTime?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User     @relation("CreatedBy", fields: [createdById], references: [id])
  assignedTo   User?    @relation("AssignedTo", fields: [assignedToId], references: [id])
  messages     TicketMessage[]

  @@index([companyId])
  @@index([status])
  @@index([assignedToId])
  @@index([createdById])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  content   String
  authorId  String
  attachments String[]
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}

model ChatRoom {
  id         String   @id @default(cuid())
  companyId  String
  name       String?
  type       String   @default("DIRECT")
  clientId   String?
  ticketId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages Message[]
  members  ChatMember[]

  @@index([companyId])
  @@map("chat_rooms")
}

model ChatMember {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  lastReadAt DateTime?
  joinedAt  DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("chat_members")
}

model Message {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  content    String
  type       String   @default("TEXT")
  attachments String[]
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@index([roomId, createdAt])
  @@map("messages")
}

model WhatsAppConnection {
  id          String   @id @default(cuid())
  companyId   String
  phoneNumber String   @unique
  name        String?
  status      String   @default("DISCONNECTED")
  qrCode      String?
  webhookUrl  String?
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]

  @@index([companyId])
  @@map("whatsapp_connections")
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  connectionId String
  from        String
  to          String
  content     String?
  mediaUrl    String?
  type        String   @default("TEXT")
  status      String   @default("SENT")
  metadata    Json?
  createdAt   DateTime @default(now())

  connection WhatsAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([from])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

model Document {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  type        String
  size        Int
  url         String
  path        String
  mimeType    String
  folderId    String?
  tags        String[]
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  folder  DocumentFolder? @relation(fields: [folderId], references: [id])

  @@index([companyId])
  @@map("documents")
}

model DocumentFolder {
  id        String   @id @default(cuid())
  companyId String
  name      String
  parentId  String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   DocumentFolder? @relation("FolderTree", fields: [parentId], references: [id])
  children DocumentFolder[] @relation("FolderTree")
  documents Document[]

  @@index([companyId])
  @@map("document_folders")
}

model Integration {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  provider    String
  type        String
  enabled     Boolean  @default(true)
  credentials Json?
  settings    Json?
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
  @@index([companyId])
  @@map("integrations")
}

model Automation {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  trigger     String
  conditions  Json?
  actions     Json
  enabled     Boolean  @default(true)
  lastRunAt   DateTime?
  runCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logs    AutomationLog[]

  @@index([companyId])
  @@map("automations")
}

model AutomationLog {
  id          String   @id @default(cuid())
  automationId String
  triggeredBy String?
  status      String
  result      Json?
  error       String?
  executedAt  DateTime @default(now())

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@map("automation_logs")
}

model Notification {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  title     String
  message   String?
  type      String   @default("INFO")
  read      Boolean  @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([companyId])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  userId     String?
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model Subscription {
  id              String             @id @default(cuid())
  companyId       String             @unique
  plan            PlanType
  status          SubscriptionStatus @default(TRIALING)
  stripeId        String?
  stripePriceId   String?
  asaasId         String?
  mercadoPagoId   String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialStart      DateTime?
  trialEnd        DateTime?
  canceledAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

model Plan {
  id          String    @id @default(cuid())
  name        String
  type        PlanType  @unique
  description String?
  price       Decimal
  currency    String    @default("BRL")
  interval    String    @default("month")
  features    Json
  limits      Json
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("plans")
}

model FeatureFlag {
  id        String   @id @default(cuid())
  name      String   @unique
  key       String   @unique
  description String?
  enabled   Boolean  @default(false)
  rules     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("feature_flags")
}

model AiConversation {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  title       String?
  provider    String   @default("OPENAI")
  model       String   @default("gpt-4")
  tokensUsed  Int      @default(0)
  cost        Decimal  @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages AiMessage[]

  @@index([companyId, userId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  tokens         Int      @default(0)
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

model AiUsage {
  id        String   @id @default(cuid())
  companyId String
  date      DateTime @default(now())
  requests  Int      @default(0)
  tokens    Int      @default(0)
  cost      Decimal  @default(0)

  @@unique([companyId, date])
  @@index([companyId])
  @@map("ai_usage")
}

model Report {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  type        String
  parameters  Json?
  data        Json?
  schedule    String?
  lastRunAt   DateTime?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@map("reports")
}
